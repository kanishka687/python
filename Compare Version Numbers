class Solution:
    def compareVersion(self, version1: str, version2: str) -> int:
        # Split both versions into lists of strings
        v1 = version1.split('.')
        v2 = version2.split('.')
        
        # Iterate through the maximum length of the two versions
        for i in range(max(len(v1), len(v2))):
            # Get the integer value or 0 if index is out of bounds
            num1 = int(v1[i]) if i < len(v1) else 0
            num2 = int(v2[i]) if i < len(v2) else 0
            
            if num1 > num2:
                return 1
            if num1 < num2:
                return -1
        
        # If all revisions are equal
        return 0
