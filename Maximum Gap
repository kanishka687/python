class Solution:
    def maximumGap(self, nums: List[int]) -> int:
        n = len(nums)
        if n < 2:
            return 0
        
        # 1. Find the range of elements
        min_val, max_val = min(nums), max(nums)
        if min_val == max_val:
            return 0
        
        # 2. Determine bucket size and count
        # Bucket size is the average gap; max gap must be at least this
        bucket_size = max(1, (max_val - min_val) // (n - 1))
        bucket_count = (max_val - min_val) // bucket_size + 1
        
        # 3. Initialize buckets with [min, max]
        buckets = [[float('inf'), float('-inf')] for _ in range(bucket_count)]
        
        # 4. Distribute elements into buckets
        for num in nums:
            idx = (num - min_val) // bucket_size
            buckets[idx][0] = min(buckets[idx][0], num)
            buckets[idx][1] = max(buckets[idx][1], num)
            
        # 5. Scan buckets to find the maximum gap
        max_gap = 0
        prev_max = min_val # Track max of the last non-empty bucket
        
        for b_min, b_max in buckets:
            if b_min == float('inf'): # Skip empty buckets
                continue
            # Gap occurs between current bucket min and previous bucket max
            max_gap = max(max_gap, b_min - prev_max)
            prev_max = b_max
            
        return max_gap
