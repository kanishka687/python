class Solution:
    def wordBreak(self, s: str, wordDict: List[str]) -> List[str]:
        word_set = set(wordDict)
        memo = {}

        def backtrack(current_s):
            # Base case: if we've processed this suffix before, return it
            if current_s in memo:
                return memo[current_s]
            
            # Base case: reached the end of the string
            if not current_s:
                return [""]
            
            res = []
            # Try every possible prefix of the current string
            for i in range(1, len(current_s) + 1):
                prefix = current_s[:i]
                if prefix in word_set:
                    # Get all possible sentences from the remaining suffix
                    suffixes = backtrack(current_s[i:])
                    for suffix in suffixes:
                        # Combine prefix and suffix with a space
                        sentence = (prefix + " " + suffix).strip()
                        res.append(sentence)
            
            memo[current_s] = res
            return res

        return backtrack(s)
