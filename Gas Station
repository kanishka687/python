class Solution:
    def canCompleteCircuit(self, gas: List[int], cost: List[int]) -> int:
        # If total gas is less than total cost, trip is impossible
        if sum(gas) < sum(cost):
            return -1
        
        total_tank = 0
        start_index = 0
        
        for i in range(len(gas)):
            total_tank += gas[i] - cost[i]
            
            # If we run out of gas, we can't start at 'start_index' 
            # or any station between 'start_index' and 'i'
            if total_tank < 0:
                # Start fresh from the next station
                start_index = i + 1
                total_tank = 0
                
        return start_index
