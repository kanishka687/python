# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, x):
#         self.val = x
#         self.next = None

class Solution:
    def detectCycle(self, head: Optional[ListNode]) -> Optional[ListNode]:
        slow = head
        fast = head
        
        # Step 1: Detect if a cycle exists
        while fast and fast.next:
            slow = slow.next
            fast = fast.next.next
            
            # Meeting point found
            if slow == fast:
                # Step 2: Find the entry point
                slow = head
                while slow != fast:
                    slow = slow.next
                    fast = fast.next
                return slow # Both now point to the start of the cycle
                
        return None
