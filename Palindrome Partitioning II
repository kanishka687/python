class Solution:
    def minCut(self, s: str) -> int:
        n = len(s)
        # Base case: empty string or single character needs 0 cuts
        if n <= 1:
            return 0

        # Step 1: Precompute a palindrome table in O(n^2)
        # is_pal[i][j] is True if s[i:j+1] is a palindrome
        is_pal = [[False] * n for _ in range(n)]
        for length in range(1, n + 1):
            for i in range(n - length + 1):
                j = i + length - 1
                if s[i] == s[j]:
                    # Length 1 or 2 with matching ends are palindromes.
                    # Otherwise, check the inner substring.
                    if length <= 2 or is_pal[i + 1][j - 1]:
                        is_pal[i][j] = True

        # Step 2: DP to find min cuts for each prefix s[0:i+1]
        cuts = [0] * n
        for i in range(n):
            # If the entire prefix s[0:i+1] is a palindrome, no cuts are needed
            if is_pal[0][i]:
                cuts[i] = 0
            else:
                # Initialize with maximum possible cuts (i cuts for i+1 characters)
                min_val = i
                for j in range(1, i + 1):
                    # If s[j:i+1] is a palindrome, cuts = cuts[j-1] + 1
                    if is_pal[j][i]:
                        min_val = min(min_val, cuts[j - 1] + 1)
                cuts[i] = min_val

        return cuts[n - 1]
