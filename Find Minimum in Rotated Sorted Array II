class Solution:
    def findMin(self, nums: List[int]) -> int:
        left, right = 0, len(nums) - 1
        
        while left < right:
            mid = left + (right - left) // 2
            
            if nums[mid] > nums[right]:
                # Min must be in the right half
                left = mid + 1
            elif nums[mid] < nums[right]:
                # Min is at mid or in the left half
                right = mid
            else:
                # nums[mid] == nums[right]: cannot tell where min is.
                # Just shrink the window from the right.
                right -= 1
                
        return nums[left]
