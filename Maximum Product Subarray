class Solution:
    def maxProduct(self, nums: List[int]) -> int:
        res = max(nums)
        cur_min, cur_max = 1, 1
        
        for n in nums:
            # If we hit 0, reset current products to 1
            if n == 0:
                cur_min, cur_max = 1, 1
                continue
            
            # Temporary storage because cur_max changes before cur_min is updated
            tmp = cur_max * n
            cur_max = max(n * cur_max, n * cur_min, n)
            cur_min = min(tmp, n * cur_min, n)
            
            res = max(res, cur_max)
            
        return res
