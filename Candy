class Solution:
    def candy(self, ratings: List[int]) -> int:
        n = len(ratings)
        # Every child starts with 1 candy
        candies = [1] * n
        
        # Left-to-Right: satisfy higher rating than left neighbor
        for i in range(1, n):
            if ratings[i] > ratings[i-1]:
                candies[i] = candies[i-1] + 1
        
        # Right-to-Left: satisfy higher rating than right neighbor
        for i in range(n - 2, -1, -1):
            if ratings[i] > ratings[i+1]:
                # Take the max to ensure both left and right rules are kept
                candies[i] = max(candies[i], candies[i+1] + 1)
        
        return sum(candies)
