"""
# Definition for a Node.
class Node:
    def __init__(self, val = 0, neighbors = None):
        self.val = val
        self.neighbors = neighbors if neighbors is not None else []
"""

class Solution:
    def __init__(self):
        # Dictionary to store original node -> cloned node mapping
        self.visited = {}

    def cloneGraph(self, node: 'Node') -> 'Node':
        if not node:
            return None

        # If the node was already cloned, return the clone from the map
        if node in self.visited:
            return self.visited[node]

        # Create the clone for the current node
        # (Don't clone neighbors yet to avoid infinite recursion)
        clone_node = Node(node.val)
        self.visited[node] = clone_node

        # Recursively clone all neighbors and add to the clone's neighbors list
        if node.neighbors:
            clone_node.neighbors = [self.cloneGraph(n) for n in node.neighbors]

        return clone_node
