class Solution:
    def wordBreak(self, s: str, wordDict: List[str]) -> bool:
        word_set = set(wordDict)
        n = len(s)
        # dp[i] means s[:i] can be segmented
        dp = [False] * (n + 1)
        dp[0] = True
        
        # Optimization: find the max length of a word in the dictionary
        max_len = max(len(w) for w in wordDict) if wordDict else 0

        for i in range(1, n + 1):
            # Check backwards from i to i - max_len
            for j in range(i - 1, max(i - max_len - 1, -1), -1):
                if dp[j] and s[j:i] in word_set:
                    dp[i] = True
                    break # No need to check other j for this i
                    
        return dp[n]
